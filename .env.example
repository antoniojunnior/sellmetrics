# App URL (sem barra final)
NEXT_PUBLIC_APP_URL=https://your-app.pages.dev

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Amazon OAuth (F1.2) ─────────────────────────────────────────────────────
# SP-API: crie um app em sellercentral.amazon.com.br/apps/manage
AMAZON_APP_ID=amzn1.sp.solution.xxx
AMAZON_CLIENT_ID=amzn1.application-oa2-client.xxx
AMAZON_CLIENT_SECRET=your-sp-api-client-secret

# Ads API: crie um perfil em advertising.amazon.com.br
AMAZON_ADS_CLIENT_ID=amzn1.application-oa2-client.xxx
AMAZON_ADS_CLIENT_SECRET=your-ads-client-secret

# ─── Amazon APIs (ingestão legada / Fase 0 fallback) ─────────────────────────
AMAZON_SP_API_CLIENT_ID=amzn1.application-oa2-client.xxx
AMAZON_SP_API_CLIENT_SECRET=your-client-secret
AMAZON_SP_API_REFRESH_TOKEN=Atzr|...
AMAZON_SP_API_REGION=us-east-1
AMAZON_ADS_API_REFRESH_TOKEN=Atzr|...

# ─── Criptografia (F1.2) ─────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-key

# ─── ASAAS (F1.4) ────────────────────────────────────────────────────────────
ASAAS_API_KEY=$aact_xxx                        # Painel ASAAS > Integrações > Chave de API
ASAAS_BASE_URL=https://api.asaas.com/api/v3    # Sandbox: https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=xxx                        # Painel ASAAS > Integrações > Webhooks
ASAAS_PRICE_STARTER=79.00
ASAAS_PRICE_PRO=149.00

# ─── Cron ────────────────────────────────────────────────────────────────────
CRON_SECRET=your-secret-here

# ─── Fase 0 fallback (substituído por accounts table na Fase 1) ──────────────
DEFAULT_ACCOUNT_ID=your-supabase-user-id
DEFAULT_MARKETPLACE_ID=A2Q3Y263D00KWC
DEFAULT_ADS_PROFILE_ID=your-ads-profile-id
