# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SP-API (Amazon Selling Partner API) — nomes exatos usados no código
AMAZON_SP_API_CLIENT_ID=amzn1.application-oa2-client.xxx
AMAZON_SP_API_CLIENT_SECRET=your-client-secret
AMAZON_SP_API_REFRESH_TOKEN=Atzr|...
AMAZON_SP_API_REGION=us-east-1

# Amazon Ads API — nomes exatos usados no código
AMAZON_ADS_API_CLIENT_ID=amzn1.application-oa2-client.xxx
AMAZON_ADS_API_CLIENT_SECRET=your-ads-client-secret
AMAZON_ADS_API_REFRESH_TOKEN=Atzr|...

# Cron job protection (gere com: openssl rand -hex 32)
CRON_SECRET=your-secret-here

# Conta padrão para ingestão (Fase 0 — substituída por consulta ao DB na Fase 1)
# DEFAULT_ACCOUNT_ID é o auth.uid() do usuário no Supabase
DEFAULT_ACCOUNT_ID=your-supabase-user-id
DEFAULT_MARKETPLACE_ID=A2Q3Y263D00KWC
DEFAULT_ADS_PROFILE_ID=your-ads-profile-id
